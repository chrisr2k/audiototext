# ============================================================
# AudioToText - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# For Docker deployment, these are set in docker-compose.yml
# or passed as environment variables to the container.
# ============================================================

# ---- OCI Credentials ----
# Leave empty to use demo mode (DEMO_MODE=true)
OCI_USER_OCID=ocid1.user.oc1..xxxxxxxxxxxxxxxx
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxxxxxxxxxxxxxx
OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx

# Path to OCI API private key file (for local development)
OCI_PRIVATE_KEY_PATH=C:/path/to/your/oci_api_key.pem

# OR: Paste the private key content directly (for Docker/production)
# OCI_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

OCI_REGION=us-ashburn-1

# OCI Object Storage (for audio file uploads and transcription results)
OCI_NAMESPACE=your-object-storage-namespace
OCI_BUCKET=your-bucket-name

# ---- App Settings ----
SECRET_KEY=change-this-to-a-random-secret-key

# Database: SQLite for local dev, PostgreSQL for production
# Local:  sqlite:///./audiototext.db
# Docker: postgresql://user:password@db:5432/audiototext
DATABASE_URL=sqlite:///./audiototext.db

# Set to false when OCI credentials are configured
DEMO_MODE=true

# ---- Admin User (for initial admin account creation) ----
# On first startup (Docker), these create the admin user automatically.
# For local dev, run: python -m app.create_admin
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# ---- Uvicorn Settings (Docker only) ----
UVICORN_WORKERS=4
LOG_LEVEL=info

# ---- PostgreSQL Settings (Docker only) ----
POSTGRES_DB=audiototext
POSTGRES_USER=audiototext
POSTGRES_PASSWORD=changeme
